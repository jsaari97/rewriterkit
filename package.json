{
  "name": "rewriterkit",
  "version": "0.0.0",
  "description": "Declarative HTML extraction library built on Cloudflare HTMLRewriter.",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.57.0",
    "vitest": "~3.2.0"
  }
}
